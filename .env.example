# ============================================================
# Variables d'environnement — amenagement-tchad
# ============================================================
# 1. Copiez ce fichier : cp .env.example .env.local
# 2. Remplissez vos valeurs (trouvées dans Supabase > Project Settings > API)
# 3. NE JAMAIS committer .env.local dans git
# ============================================================

# URL du projet Supabase
VITE_SUPABASE_URL=https://VOTRE_ID_PROJET.supabase.co

# Clé publique Supabase (publishable key — Settings > API > Project API keys)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
